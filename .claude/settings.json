      "Write(.github/workflows/*)",
      "Write(package-lock.json)",
      "Write(production.*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Bash(npx vercel *)",
      "Bash(vercel *)",
      "Bash(npx supabase db push *)",
      "Bash(npx supabase db reset *)",
      "Bash(supabase db push *)",
      "Bash(supabase db reset *)",
      "Bash(docker *)",
      "Bash(curl * | sh)",
      "Bash(wget *)"
    ],
    "defaultMode": "acceptEdits"
  }
}
